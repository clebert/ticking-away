{
  "name": "ticking-away",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "zig build && vite build",
    "ci": "npm run build && npm run lint && npm test",
    "lint": "tsc && biome check && prettier --check \"**/*.{html,md,yaml,yml}\" && zig fmt --check .",
    "lint:fix": "biome check --write --unsafe && prettier --write \"**/*.{html,md,yaml,yml}\" && zig fmt .",
    "start": "vite",
    "test": "zig build test"
  },
  "dependencies": {
    "@preact/signals": "^2.7.1",
    "preact": "^10.28.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@preact/preset-vite": "^2.10.3",
    "@types/node": "^25.0.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
