{
  "name": "ticking-away",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "prebuild": "./build.sh",
    "check": "biome check",
    "check:fix": "biome check --write --unsafe",
    "ci": "npm run build && npm run check && npm run compile && npm run format",
    "compile": "tsc",
    "format": "prettier --check \"**/*.{md,yaml,yml}\"",
    "format:fix": "prettier --write \"**/*.{md,yaml,yml}\"",
    "start": "vite"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^25.0.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@preact/signals-core": "^1.12.1"
  }
}
