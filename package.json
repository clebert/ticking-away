{
  "name": "ticking-away",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "zig build && vite build",
    "ci": "npm run build && npm run lint && npm test",
    "lint": "tsc && biome check && prettier --check \"**/*.{html,md,yaml,yml}\" && zig fmt --check .",
    "lint:fix": "biome check --write --unsafe && prettier --write \"**/*.{html,md,yaml,yml}\" && zig fmt .",
    "start": "vite",
    "test": "zig build test"
  },
  "dependencies": {
    "@preact/signals": "^2.9.1",
    "preact": "^10.29.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
