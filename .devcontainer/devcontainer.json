{
  "name": "ticking-away",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "24",
      "pnpmVersion": "latest",
      "nvmVersion": "latest"
    }
  },
  "mounts": ["source=claude-config,target=/home/vscode/claude-config,type=volume"],
  "containerEnv": { "CLAUDE_CONFIG_DIR": "/home/vscode/claude-config" },
  "postCreateCommand": "npm install && sudo chown -R vscode:vscode /home/vscode/claude-config && curl -fsSL https://claude.ai/install.sh | bash"
}
